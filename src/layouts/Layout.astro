<body>
<slot />
<script>
(function() {
  var P = 'rainbow696969';
  if (sessionStorage.getItem('auth') !== P) {
    var o = document.createElement('div');
    o.id = 'pw-overlay';
    o.style.cssText = 'position:fixed;inset:0;background:#0f172a;display:flex;align-items:center;justify-content:center;z-index:9999;font-family:system-ui,sans-serif';
    o.innerHTML = '<div style="text-align:center;color:#fff;padding:2rem"><h2 style="margin-bottom:1.5rem">Protected Page</h2><input id="pw-in" type="password" placeholder="Enter password" style="padding:.6rem 1rem;font-size:1rem;border-radius:6px;border:none;margin-right:.5rem;width:200px" /><button id="pw-btn" style="padding:.6rem 1.2rem;font-size:1rem;background:#7c3aed;color:#fff;border:none;border-radius:6px;cursor:pointer">Enter</button><p id="pw-err" style="color:#f87171;margin-top:.75rem;display:none">Wrong password.</p></div>';
    document.body.appendChild(o);
    function check() {
      if (document.getElementById('pw-in').value === P) {
        sessionStorage.setItem('auth', P);
        document.getElementById('pw-overlay').remove();
      } else {
        document.getElementById('pw-err').style.display = 'block';
      }
    }
    document.getElementById('pw-btn').addEventListener('click', check);
    document.getElementById('pw-in').addEventListener('keydown', function(e) { if (e.key === 'Enter') check(); });
  }
})();
</script>
